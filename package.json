{
  "name": "vulnot",
  "version": "1.0.0",
  "private": true,
  "description": "VULNOT - Vulnerable OT Security Training Platform by Mjolnir Security",
  "scripts": {
    "dev": "docker-compose -f infrastructure/docker/docker-compose.yml up",
    "dev:dashboard": "cd apps/dashboard && npm run dev",
    "dev:api": "cd apps/api && uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "build": "npm run build:dashboard",
    "build:dashboard": "cd apps/dashboard && npm run build",
    "start": "docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "stop": "docker-compose -f infrastructure/docker/docker-compose.yml down",
    "reset": "docker-compose -f infrastructure/docker/docker-compose.yml down -v && docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "logs": "docker-compose -f infrastructure/docker/docker-compose.yml logs -f",
    "test": "npm run test:api && npm run test:dashboard",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mjolnirsecurity/vulnot.git"
  },
  "homepage": "https://github.com/mjolnirsecurity/vulnot",
  "bugs": {
    "url": "https://github.com/mjolnirsecurity/vulnot/issues"
  },
  "keywords": [
    "ot-security",
    "ics",
    "scada",
    "pentesting",
    "training",
    "modbus",
    "dnp3",
    "s7comm",
    "opcua",
    "industrial-control-systems",
    "cybersecurity"
  ],
  "author": {
    "name": "Milind Bhargava",
    "email": "training@mjolnirsecurity.com",
    "url": "https://mjolnirsecurity.com"
  },
  "contributors": [
    {
      "name": "Mjolnir Security Team"
    }
  ],
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0"
  }
}
