# =============================================================================
# VULNOT Environment Configuration
# =============================================================================
# Copy this file to .env and customize values for your deployment.
# WARNING: Never commit .env to version control.
# =============================================================================

# --- Database Credentials ---
INFLUXDB_ADMIN_TOKEN=vulnot-super-secret-token
INFLUXDB_ADMIN_PASSWORD=vulnotpassword

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=vulnot

# --- Redis ---
REDIS_PASSWORD=vulnot-redis-pass

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080

# --- Application ---
DEBUG=false
