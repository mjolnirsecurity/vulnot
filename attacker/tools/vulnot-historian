@cli.command()
@click.option('--network', '-n', required=True, help='Network to scan (e.g., 10.0.9.0/24)')
@click.option('--ports', '-p', default='8080,8443,502,1433,5432', help='Ports to scan')
def scan(network: str, ports: str):
    """Scan network for historian servers"""
    console.print("\n[bold blue]╔════════════════════════════════════════╗[/]")
    console.print("[bold blue]║     VULNOT OT Historian Scanner        ║[/]")
    console.print("[bold blue]╚════════════════════════════════════════╝[/]\n")

    port_list = [int(p.strip()) for p in ports.split(',')]
    console.print(f"[yellow]Scanning:[/] {network}")
    console.print(f"[yellow]Ports:[/] {port_list}\n")

    import ipaddress
    try:
        net = ipaddress.ip_network(network, strict=False)
    except ValueError as e:
        console.print(f"[red]Invalid network: {e}[/]")
        return

    found = []
    with console.status("[bold green]Scanning...") as status:
        for ip in net.hosts():
            ip_str = str(ip)
            for port in port_list:
                try:
                    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                    sock.settimeout(0.3)
                    result = sock.connect_ex((ip_str, port))
                    if result == 0:
                        service = {
                            8080: "HTTP",
                            8443: "HTTPS",
                            502: "Modbus",
                            1433: "SQL Server",
                            5432: "PostgreSQL"
                        }.get(port, "Unknown")
                        found.append({'ip': ip_str, 'port': port, 'service': service})
                    sock.close()
                except:
                    pass

    if found:
        table = Table(title="Discovered Historian Services")
        table.add_column("IP Address", style="cyan")
        table.add_column("Port", style="white")
        table.add_column("Service", style="green")

        for dev in found:
            table.add_row(dev['ip'], str(dev['port']), dev['service'])

        console.print(table)
    else:
        console.print("[yellow]No historian services found[/]")

    console.print(f"\n[green]Found {len(found)} service(s)[/]\n")

