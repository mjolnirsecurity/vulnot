@cli.command()
@click.option('--network', '-n', required=True, help='Network to scan (e.g., 10.0.3.0/24)')
@click.option('--port', '-p', default=102, help='S7comm port (default: 102)')
def scan(network: str, port: int):
    """Scan network for S7 PLCs"""
    console.print("\n[bold blue]╔════════════════════════════════════════╗[/]")
    console.print("[bold blue]║       VULNOT S7comm PLC Scanner        ║[/]")
    console.print("[bold blue]╚════════════════════════════════════════╝[/]\n")

    console.print(f"[yellow]Scanning:[/] {network} on port {port}\n")

    import ipaddress
    try:
        net = ipaddress.ip_network(network, strict=False)
    except ValueError as e:
        console.print(f"[red]Invalid network: {e}[/]")
        return

    found = []
    with console.status("[bold green]Scanning...") as status:
        for ip in net.hosts():
            ip_str = str(ip)
            try:
                sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                sock.settimeout(0.5)
                result = sock.connect_ex((ip_str, port))
                if result == 0:
                    found.append({'ip': ip_str, 'port': port, 'model': 'S7-1500'})
                sock.close()
            except:
                pass

    if found:
        table = Table(title="Discovered S7 PLCs")
        table.add_column("IP Address", style="cyan")
        table.add_column("Port", style="white")
        table.add_column("Model", style="green")

        for dev in found:
            table.add_row(dev['ip'], str(dev['port']), dev['model'])

        console.print(table)
    else:
        console.print("[yellow]No S7 PLCs found[/]")

    console.print(f"\n[green]Found {len(found)} S7 PLC(s)[/]\n")

