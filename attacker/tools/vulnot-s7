# S7comm constants
COTP_CR = b'\x03\x00\x00\x16\x11\xe0\x00\x00\x00\x01\x00\xc0\x01\x0a\xc1\x02\x01\x00\xc2\x02\x01\x02'
S7_SETUP = b'\x03\x00\x00\x19\x02\xf0\x80\x32\x01\x00\x00\x00\x00\x00\x08\x00\x00\xf0\x00\x00\x01\x00\x01\x00\xf0'

def s7_connect(ip: str, port: int = 102, timeout: float = 5.0) -> socket.socket:
    """Establish S7 connection"""
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(timeout)
    sock.connect((ip, port))

    # Send COTP Connection Request
    sock.send(COTP_CR)
    response = sock.recv(1024)

    # Send S7 Communication Setup
    sock.send(S7_SETUP)
    response = sock.recv(1024)

    return sock

def s7_read_db(sock: socket.socket, db_number: int, start: int = 0, size: int = 100) -> bytes:
    """Read data block from S7 PLC"""
    # Build read request
    # TPKT header
    tpkt = b'\x03\x00'

    # COTP header
    cotp = b'\x02\xf0\x80'

    # S7 Header
    s7_header = b'\x32\x01\x00\x00\x00\x00\x00\x0e\x00\x00\x04\x01\x12\x0a\x10'

    # Read parameters
    transport_size = b'\x02'  # BYTE
    length = struct.pack('>H', size)
    db_num = struct.pack('>H', db_number)
    area = b'\x84'  # DB
    address = struct.pack('>I', start * 8)[1:]  # Bit address

    request = s7_header + transport_size + length + db_num + area + address

    # Calculate total length
    total_len = len(cotp) + len(request)
    tpkt += struct.pack('>H', total_len + 4)

    packet = tpkt + cotp + request
    sock.send(packet)

    response = sock.recv(4096)
    return response

