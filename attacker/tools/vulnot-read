def read_holding_registers(ip: str, port: int, unit_id: int, start: int, count: int, timeout: float = 2.0) -> list:
    """Read holding registers from Modbus device"""
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(timeout)
    
    try:
        sock.connect((ip, port))
        
        # Build Modbus request
        transaction_id = 1
        protocol_id = 0
        length = 6
        function_code = 0x03  # Read Holding Registers
        
        request = struct.pack('>H H H B B H H', 
                             transaction_id, protocol_id, length,
                             unit_id, function_code, start, count)
        
        sock.send(request)
        response = sock.recv(1024)
        
        if len(response) >= 9:
            # Parse response
            resp_fc = response[7]
            if resp_fc == function_code:
                byte_count = response[8]
                values = []
                for i in range(0, byte_count, 2):
                    value = struct.unpack('>H', response[9+i:11+i])[0]
                    values.append(value)
                return values
            elif resp_fc == (function_code | 0x80):
                exception_code = response[8]
                raise Exception(f"Modbus exception: {exception_code}")
        
        return []
        
    finally:
        sock.close()

def read_coils(ip: str, port: int, unit_id: int, start: int, count: int, timeout: float = 2.0) -> list:
    """Read coils from Modbus device"""
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(timeout)
    
    try:
        sock.connect((ip, port))
        
        # Build Modbus request
        transaction_id = 1
        protocol_id = 0
        length = 6
        function_code = 0x01  # Read Coils
        
        request = struct.pack('>H H H B B H H', 
                             transaction_id, protocol_id, length,
                             unit_id, function_code, start, count)
        
        sock.send(request)
        response = sock.recv(1024)
        
        if len(response) >= 9:
            resp_fc = response[7]
            if resp_fc == function_code:
                byte_count = response[8]
                coil_bytes = response[9:9+byte_count]
                
                # Convert bytes to individual coil values
                coils = []
                for byte in coil_bytes:
                    for bit in range(8):
                        if len(coils) < count:
                            coils.append((byte >> bit) & 1)
                return coils
        
        return []
        
    finally:
        sock.close()

@click.command()
@click.option('--target', '-t', required=True, help='Target IP address')
@click.option('--port', '-p', default=502, help='Modbus port (default: 502)')
@click.option('--unit', '-u', default=1, help='Unit ID (default: 1)')
@click.option('--register', '-r', default=0, help='Start register (default: 0)')
@click.option('--count', '-c', default=10, help='Number of registers (default: 10)')
@click.option('--coils', is_flag=True, help='Read coils instead of holding registers')
@click.option('--raw', is_flag=True, help='Show raw values without interpretation')
def main(target: str, port: int, unit: int, register: int, count: int, coils: bool, raw: bool):
    """VULNOT Modbus Register Reader"""
    
    console.print("\n[bold blue]╔═══════════════════════════════════════╗[/]")
    console.print("[bold blue]║     VULNOT Modbus Register Reader     ║[/]")
    console.print("[bold blue]╚═══════════════════════════════════════╝[/]\n")
    
    # Get PLC info if known
    plc_info = PLC_MAPS.get(unit, {})
    if plc_info:
        console.print(Panel(
            f"[cyan]{plc_info['name']}[/] - {plc_info['description']}",
            title="Device Info"
        ))
    
    console.print(f"[yellow]Target:[/] {target}:{port}")
    console.print(f"[yellow]Unit ID:[/] {unit}")
    console.print(f"[yellow]Reading:[/] {'Coils' if coils else 'Holding Registers'} {register}-{register+count-1}\n")
    
    try:
        if coils:
            values = read_coils(target, port, unit, register, count)
            
            table = Table(title=f"Coils from {target}")
            table.add_column("Address", style="cyan")
            table.add_column("Name", style="white")
            table.add_column("Value", style="green")
            table.add_column("Status", style="yellow")
            
            coil_map = plc_info.get('coils', {})
            
            for i, val in enumerate(values):
                addr = register + i
                name = coil_map.get(i, f"Coil {addr}")
                status = "[green]ON[/]" if val else "[red]OFF[/]"
                table.add_row(str(addr), name, str(val), status)
            
            console.print(table)
            
        else:
            values = read_holding_registers(target, port, unit, register, count)
            
            table = Table(title=f"Holding Registers from {target}")
            table.add_column("Address", style="cyan")
            table.add_column("Name", style="white")
            table.add_column("Raw", style="blue")
            table.add_column("Scaled", style="green")
            table.add_column("Unit", style="yellow")
            
            reg_map = plc_info.get('holding_registers', {})
            
            for i, val in enumerate(values):
                addr = register + i
                
                if addr in reg_map and not raw:
                    name, unit_str, scale = reg_map[addr]
                    scaled = val / scale if scale > 1 else val
                    table.add_row(str(addr), name, str(val), f"{scaled:.2f}", unit_str)
                else:
                    table.add_row(str(addr), f"HR{addr}", str(val), str(val), "-")
            
            console.print(table)
        
        console.print("\n[bold green]Read successful![/]\n")
        
        # Exploitation hints
        if not raw and plc_info:
            console.print("[bold yellow]💡 Exploitation Tips:[/]")
            console.print("  • Coils control equipment ON/OFF state (pumps, valves)")
            console.print("  • Holding registers contain setpoints and process values")
            console.print("  • No authentication required - anyone can read/write!")
            console.print(f"  • Try: vulnot-write -t {target} -u {unit} -r 0 -v <VALUE>")
            console.print("")
            
    except Exception as e:
        console.print(f"[red]Error:[/] {e}\n")

if __name__ == '__main__':
    main()
