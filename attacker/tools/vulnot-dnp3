# DNP3 Function Codes
DNP3_READ = 0x01
DNP3_WRITE = 0x02
DNP3_SELECT = 0x03
DNP3_OPERATE = 0x04
DNP3_DIRECT_OPERATE = 0x05
DNP3_COLD_RESTART = 0x0D
DNP3_WARM_RESTART = 0x0E

def build_dnp3_request(src: int, dst: int, func_code: int, data: bytes = b'') -> bytes:
    """Build a DNP3 request frame"""
    # Start bytes
    start = b'\x05\x64'

    # Length (data link layer)
    length = 5 + len(data)

    # Control byte (DIR=1, PRM=1, FCB=0, FCV=0, FC=0)
    control = 0xC0

    # Destination and source (little endian)
    dst_bytes = struct.pack('<H', dst)
    src_bytes = struct.pack('<H', src)

    # CRC placeholder (simplified - real DNP3 uses CRC-16)
    crc = b'\x00\x00'

    # Build data link header
    header = start + bytes([length, control]) + dst_bytes + src_bytes + crc

    # Transport layer (FIR=1, FIN=1, sequence=0)
    transport = bytes([0xC0])

    # Application layer
    app_control = bytes([0xC0])  # FIR=1, FIN=1, CON=0, UNS=0, SEQ=0
    app_func = bytes([func_code])

    # Build full frame
    frame = header + transport + app_control + app_func + data

    return frame

def send_dnp3(ip: str, port: int, frame: bytes, timeout: float = 5.0) -> bytes:
    """Send DNP3 frame and receive response"""
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(timeout)

    try:
        sock.connect((ip, port))
        sock.send(frame)
        response = sock.recv(4096)
        return response
    finally:
        sock.close()

