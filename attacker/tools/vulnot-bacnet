@click.option('--port', '-p', default=47808, help='BACnet port (default: 47808)')
def discover(network: str, port: int):
    """Discover BACnet devices using Who-Is broadcast"""
    console.print("\n[bold blue]╔════════════════════════════════════════╗[/]")
    console.print("[bold blue]║      VULNOT BACnet Device Discovery    ║[/]")
    console.print("[bold blue]╚════════════════════════════════════════╝[/]\n")

    console.print(f"[yellow]Broadcasting Who-Is to:[/] {network}:{port}\n")

    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        sock.settimeout(3.0)
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_BROADCAST, 1)
        sock.bind(('', port))

        # Send Who-Is
        who_is = build_who_is()
        sock.sendto(who_is, (network, port))

        console.print("[yellow]Listening for I-Am responses...[/]\n")

        found = []
        try:
            while True:
                response, addr = sock.recvfrom(4096)
                found.append({
                    'ip': addr[0],
                    'port': addr[1],
                    'device_id': 'Unknown'
                })
        except socket.timeout:
            pass

        sock.close()

        if found:
            table = Table(title="Discovered BACnet Devices")
            table.add_column("IP Address", style="cyan")
            table.add_column("Port", style="white")
            table.add_column("Device ID", style="green")

            for dev in found:
                table.add_row(dev['ip'], str(dev['port']), dev['device_id'])

            console.print(table)
        else:
            console.print("[yellow]No BACnet devices responded[/]")
            console.print("[dim]Try scanning individual IPs with 'vulnot-bacnet scan'[/]")

    except Exception as e:
        console.print(f"[red]Error: {e}[/]")

    console.print(f"\n[green]Discovery complete[/]\n")

@cli.command()
@click.option('--network', '-n', required=True, help='Network to scan (e.g., 10.0.5.0/24)')
@click.option('--port', '-p', default=47808, help='BACnet port (default: 47808)')
def scan(network: str, port: int):
    """Scan network for BACnet devices"""
    console.print("\n[bold blue]╔════════════════════════════════════════╗[/]")
    console.print("[bold blue]║      VULNOT BACnet Network Scanner     ║[/]")
    console.print("[bold blue]╚════════════════════════════════════════╝[/]\n")

    console.print(f"[yellow]Scanning:[/] {network} on port {port}\n")

    import ipaddress
    try:
        net = ipaddress.ip_network(network, strict=False)
    except ValueError as e:
        console.print(f"[red]Invalid network: {e}[/]")
        return

    found = []
    with console.status("[bold green]Scanning...") as status:
        for ip in net.hosts():
            ip_str = str(ip)
            try:
                sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
                sock.settimeout(0.3)

                who_is = build_who_is()
                sock.sendto(who_is, (ip_str, port))

                try:
                    response, addr = sock.recvfrom(4096)
                    found.append({'ip': ip_str, 'port': port, 'status': 'BACnet'})
                except socket.timeout:
                    pass

                sock.close()
            except:
                pass

    if found:
        table = Table(title="Discovered BACnet Devices")
        table.add_column("IP Address", style="cyan")
        table.add_column("Port", style="white")
        table.add_column("Status", style="green")

        for dev in found:
            table.add_row(dev['ip'], str(dev['port']), dev['status'])

        console.print(table)
    else:
        console.print("[yellow]No BACnet devices found[/]")

    console.print(f"\n[green]Found {len(found)} BACnet device(s)[/]\n")

