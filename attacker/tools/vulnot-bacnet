# BACnet Constants
BACNET_PORT = 47808
BVLC_TYPE_IP = 0x81
BVLC_FUNC_UNICAST = 0x0A
BVLC_FUNC_BROADCAST = 0x0B
BVLC_FUNC_ORIGINAL_BROADCAST = 0x0B

# BACnet Services
BACNET_WHO_IS = 0x08
BACNET_I_AM = 0x00
BACNET_READ_PROPERTY = 0x0C
BACNET_WRITE_PROPERTY = 0x0F

def build_who_is() -> bytes:
    """Build BACnet Who-Is broadcast packet"""
    # BVLC Header
    bvlc_type = bytes([BVLC_TYPE_IP])
    bvlc_function = bytes([BVLC_FUNC_ORIGINAL_BROADCAST])

    # NPDU
    npdu_version = bytes([0x01])
    npdu_control = bytes([0x20])  # Expecting reply

    # APDU - Who-Is (unconfirmed)
    apdu_type = bytes([0x10])  # Unconfirmed request
    service_choice = bytes([BACNET_WHO_IS])

    payload = npdu_version + npdu_control + apdu_type + service_choice
    length = struct.pack('>H', 4 + len(payload))

    return bvlc_type + bvlc_function + length + payload

def build_read_property(device_id: int, object_type: int, instance: int, property_id: int) -> bytes:
    """Build BACnet Read Property request"""
    # BVLC Header
    bvlc_type = bytes([BVLC_TYPE_IP])
    bvlc_function = bytes([BVLC_FUNC_UNICAST])

    # NPDU
    npdu_version = bytes([0x01])
    npdu_control = bytes([0x04])  # Expecting reply

    # APDU - Confirmed Request
    apdu_type = bytes([0x00])  # Confirmed request
    max_resp = bytes([0x04])  # Max response segments
    invoke_id = bytes([0x01])
    service_choice = bytes([BACNET_READ_PROPERTY])

    # Object Identifier (context tag 0)
    obj_id = (object_type << 22) | instance
    obj_tag = bytes([0x0C])  # Context tag 0, length 4
    obj_value = struct.pack('>I', obj_id)

    # Property Identifier (context tag 1)
    prop_tag = bytes([0x19])  # Context tag 1, length 1
    prop_value = bytes([property_id])

    payload = npdu_version + npdu_control + apdu_type + max_resp + invoke_id + \
              service_choice + obj_tag + obj_value + prop_tag + prop_value

    length = struct.pack('>H', 4 + len(payload))

    return bvlc_type + bvlc_function + length + payload

def send_bacnet_udp(ip: str, port: int, data: bytes, timeout: float = 2.0) -> bytes:
    """Send BACnet UDP packet"""
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.settimeout(timeout)
    sock.setsockopt(socket.SOL_SOCKET, socket.SO_BROADCAST, 1)

    try:
        sock.sendto(data, (ip, port))
        response, addr = sock.recvfrom(4096)
        return response
    except socket.timeout:
        return None
    finally:
        sock.close()

