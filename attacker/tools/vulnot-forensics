            console.print(f"[green]✓[/] Collected: {item}")
            time.sleep(0.3)

    console.print("\n[green]Evidence collection complete![/]\n")

    # Display evidence tree
    tree = Tree(f"[bold]{evidence_dir}[/]")

    network = tree.add("[cyan]network/[/]")
    network.add("capture.pcap (245 MB)")
    network.add("device_configs/")

    plc = tree.add("[cyan]plc/[/]")
    plc.add("program_backup.bin (1.2 MB)")
    plc.add("diagnostic_buffer.txt (45 KB)")

    historian = tree.add("[cyan]historian/[/]")
    historian.add("db_dump.sql (2.5 GB)")
    historian.add("audit.log (125 MB)")

    logs = tree.add("[cyan]logs/[/]")
    logs.add("hmi_screenshots/ (15 files)")
    logs.add("windows_events.evtx (50 MB)")
    logs.add("alarm_history.csv (8 MB)")

    memory = tree.add("[cyan]memory/[/]")
    memory.add("plc_memory.bin (64 KB)")

    console.print(tree)

