            ("Historian audit logs", "historian/audit.log"),
            ("HMI screenshots", "logs/hmi_screenshots/"),
            ("Windows event logs", "logs/windows_events.evtx"),
            ("Network device configs", "network/device_configs/"),
            ("Memory dump", "memory/plc_memory.bin"),
            ("Alarm history", "logs/alarm_history.csv"),
        ]

