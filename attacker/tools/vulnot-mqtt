# MQTT Control Packet Types
MQTT_CONNECT = 0x10
MQTT_CONNACK = 0x20
MQTT_PUBLISH = 0x30
MQTT_SUBSCRIBE = 0x82
MQTT_SUBACK = 0x90
MQTT_PINGREQ = 0xC0
MQTT_PINGRESP = 0xD0
MQTT_DISCONNECT = 0xE0

def encode_remaining_length(length: int) -> bytes:
    """Encode MQTT remaining length"""
    result = bytearray()
    while True:
        byte = length % 128
        length = length // 128
        if length > 0:
            byte = byte | 0x80
        result.append(byte)
        if length == 0:
            break
    return bytes(result)

def build_connect(client_id: str = "vulnot-attacker") -> bytes:
    """Build MQTT CONNECT packet"""
    # Variable header
    protocol_name = b'\x00\x04MQTT'
    protocol_level = bytes([0x04])  # MQTT 3.1.1
    connect_flags = bytes([0x02])  # Clean session
    keep_alive = struct.pack('>H', 60)

    # Payload
    client_id_bytes = client_id.encode('utf-8')
    client_id_len = struct.pack('>H', len(client_id_bytes))

    variable_header = protocol_name + protocol_level + connect_flags + keep_alive
    payload = client_id_len + client_id_bytes

    remaining_length = encode_remaining_length(len(variable_header) + len(payload))

    return bytes([MQTT_CONNECT]) + remaining_length + variable_header + payload

def build_subscribe(topic: str, packet_id: int = 1) -> bytes:
    """Build MQTT SUBSCRIBE packet"""
    # Variable header
    packet_id_bytes = struct.pack('>H', packet_id)

    # Payload
    topic_bytes = topic.encode('utf-8')
    topic_len = struct.pack('>H', len(topic_bytes))
    qos = bytes([0x00])  # QoS 0

    payload = topic_len + topic_bytes + qos
    remaining_length = encode_remaining_length(len(packet_id_bytes) + len(payload))

    return bytes([MQTT_SUBSCRIBE]) + remaining_length + packet_id_bytes + payload

def build_publish(topic: str, message: str, retain: bool = False) -> bytes:
    """Build MQTT PUBLISH packet"""
    # Fixed header
    flags = 0x00
    if retain:
        flags |= 0x01

    # Variable header
    topic_bytes = topic.encode('utf-8')
    topic_len = struct.pack('>H', len(topic_bytes))

    # Payload
    message_bytes = message.encode('utf-8')

    variable_header = topic_len + topic_bytes
    remaining_length = encode_remaining_length(len(variable_header) + len(message_bytes))

    return bytes([MQTT_PUBLISH | flags]) + remaining_length + variable_header + message_bytes

class MQTTClient:
    def __init__(self, host: str, port: int = 1883, timeout: float = 5.0):
        self.host = host
        self.port = port
        self.timeout = timeout
        self.sock = None

    def connect(self) -> bool:
        """Connect to MQTT broker"""
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.sock.settimeout(self.timeout)
        self.sock.connect((self.host, self.port))

        # Send CONNECT
        connect_packet = build_connect()
        self.sock.send(connect_packet)

        # Wait for CONNACK
        response = self.sock.recv(4)
        if response[0] == MQTT_CONNACK:
            return True
        return False

    def subscribe(self, topic: str) -> bool:
        """Subscribe to topic"""
        sub_packet = build_subscribe(topic)
        self.sock.send(sub_packet)

        response = self.sock.recv(5)
        if response[0] == MQTT_SUBACK:
            return True
        return False

    def publish(self, topic: str, message: str, retain: bool = False):
        """Publish message to topic"""
        pub_packet = build_publish(topic, message, retain)
        self.sock.send(pub_packet)

    def receive(self, timeout: float = 1.0) -> tuple:
        """Receive a message"""
        self.sock.settimeout(timeout)
        try:
            data = self.sock.recv(4096)
            if data and (data[0] & 0xF0) == MQTT_PUBLISH:
                # Parse PUBLISH packet
                idx = 1
                multiplier = 1
                remaining_length = 0
                while True:
                    byte = data[idx]
                    remaining_length += (byte & 127) * multiplier
                    multiplier *= 128
                    idx += 1
                    if (byte & 128) == 0:
                        break

                topic_len = struct.unpack('>H', data[idx:idx+2])[0]
                idx += 2
                topic = data[idx:idx+topic_len].decode('utf-8')
                idx += topic_len
                message = data[idx:idx+remaining_length-2-topic_len].decode('utf-8')

                return (topic, message)
        except socket.timeout:
            pass
        return (None, None)

    def disconnect(self):
        """Disconnect from broker"""
        if self.sock:
            self.sock.send(bytes([MQTT_DISCONNECT, 0x00]))
            self.sock.close()

