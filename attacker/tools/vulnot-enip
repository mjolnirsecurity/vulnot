@cli.command()
@click.option('--network', '-n', required=True, help='Network to scan (e.g., 10.0.6.0/24)')
@click.option('--port', '-p', default=44818, help='EtherNet/IP port (default: 44818)')
def scan(network: str, port: int):
    """Scan network for EtherNet/IP devices"""
    console.print("\n[bold blue]╔════════════════════════════════════════╗[/]")
    console.print("[bold blue]║    VULNOT EtherNet/IP Device Scanner   ║[/]")
    console.print("[bold blue]╚════════════════════════════════════════╝[/]\n")

    console.print(f"[yellow]Scanning:[/] {network} on port {port}\n")

    import ipaddress
    try:
        net = ipaddress.ip_network(network, strict=False)
    except ValueError as e:
        console.print(f"[red]Invalid network: {e}[/]")
        return

    found = []
    with console.status("[bold green]Scanning...") as status:
        for ip in net.hosts():
            ip_str = str(ip)
            try:
                sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                sock.settimeout(0.5)
                result = sock.connect_ex((ip_str, port))
                if result == 0:
                    found.append({'ip': ip_str, 'port': port, 'status': 'EtherNet/IP'})
                sock.close()
            except:
                pass

    if found:
        table = Table(title="Discovered EtherNet/IP Devices")
        table.add_column("IP Address", style="cyan")
        table.add_column("Port", style="white")
        table.add_column("Status", style="green")

        for dev in found:
            table.add_row(dev['ip'], str(dev['port']), dev['status'])

        console.print(table)
    else:
        console.print("[yellow]No EtherNet/IP devices found[/]")

    console.print(f"\n[green]Found {len(found)} EtherNet/IP device(s)[/]\n")

