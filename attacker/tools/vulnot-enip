# EtherNet/IP Constants
ENIP_PORT = 44818
ENIP_COMMAND_NOP = 0x0000
ENIP_COMMAND_LIST_SERVICES = 0x0004
ENIP_COMMAND_LIST_IDENTITY = 0x0063
ENIP_COMMAND_LIST_INTERFACES = 0x0064
ENIP_COMMAND_REGISTER_SESSION = 0x0065
ENIP_COMMAND_UNREGISTER_SESSION = 0x0066
ENIP_COMMAND_SEND_RR_DATA = 0x006F
ENIP_COMMAND_SEND_UNIT_DATA = 0x0070

def build_enip_header(command: int, session: int = 0, data: bytes = b'') -> bytes:
    """Build EtherNet/IP encapsulation header"""
    header = struct.pack('<H', command)  # Command
    header += struct.pack('<H', len(data))  # Length
    header += struct.pack('<I', session)  # Session Handle
    header += struct.pack('<I', 0)  # Status
    header += b'\x00' * 8  # Sender Context
    header += struct.pack('<I', 0)  # Options
    return header + data

def build_list_identity() -> bytes:
    """Build List Identity request"""
    return build_enip_header(ENIP_COMMAND_LIST_IDENTITY)

def build_register_session() -> bytes:
    """Build Register Session request"""
    data = struct.pack('<H', 1)  # Protocol Version
    data += struct.pack('<H', 0)  # Options Flags
    return build_enip_header(ENIP_COMMAND_REGISTER_SESSION, 0, data)

def send_enip(ip: str, port: int, data: bytes, timeout: float = 5.0) -> bytes:
    """Send EtherNet/IP packet and receive response"""
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(timeout)

    try:
        sock.connect((ip, port))
        sock.send(data)
        response = sock.recv(4096)
        return response
    finally:
        sock.close()

