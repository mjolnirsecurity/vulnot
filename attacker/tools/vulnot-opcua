        if response:
            console.print("[green]Node value read![/]\n")

            # Simulated values for training
            values = {
                "Temperature": ("185.5", "°C", "REAL"),
                "Pressure": ("45.2", "bar", "REAL"),
                "Level": ("78.5", "%", "REAL"),
                "FlowRate": ("125.0", "L/min", "REAL"),
                "TemperatureSP": ("180.0", "°C", "REAL"),
                "EmergencyStop": ("FALSE", "", "BOOL"),
            }

            # Find matching node
            for name, (value, unit, dtype) in values.items():
                if name.lower() in node.lower():
                    table = Table(title=f"Node: {node}")
                    table.add_column("Property", style="cyan")
                    table.add_column("Value", style="white")

                    table.add_row("Node ID", node)
                    table.add_row("Data Type", dtype)
                    table.add_row("Value", f"{value} {unit}")
                    table.add_row("Status", "[green]Good[/]")
                    table.add_row("Timestamp", "2024-01-01T12:00:00Z")

                    console.print(table)
                    return

            console.print(f"[yellow]Node {node} not found in address space[/]")

    except Exception as e:
        console.print(f"[red]Error: {e}[/]")

