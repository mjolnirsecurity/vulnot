# OPC UA Message Types
OPC_UA_HELLO = b'HEL'
OPC_UA_ACKNOWLEDGE = b'ACK'
OPC_UA_ERROR = b'ERR'
OPC_UA_OPEN = b'OPN'
OPC_UA_CLOSE = b'CLO'
OPC_UA_MESSAGE = b'MSG'

def build_hello_message(endpoint_url: str) -> bytes:
    """Build OPC UA Hello message"""
    url_bytes = endpoint_url.encode('utf-8')

    # Hello message body
    protocol_version = struct.pack('<I', 0)  # Version 0
    receive_buffer_size = struct.pack('<I', 65535)
    send_buffer_size = struct.pack('<I', 65535)
    max_message_size = struct.pack('<I', 0)  # No limit
    max_chunk_count = struct.pack('<I', 0)  # No limit
    endpoint_url_length = struct.pack('<I', len(url_bytes))

    body = protocol_version + receive_buffer_size + send_buffer_size + \
           max_message_size + max_chunk_count + endpoint_url_length + url_bytes

    # Header
    message_type = OPC_UA_HELLO
    chunk_type = b'F'  # Final
    message_size = struct.pack('<I', 8 + len(body))

    return message_type + chunk_type + message_size + body

def send_opcua(ip: str, port: int, data: bytes, timeout: float = 5.0) -> bytes:
    """Send OPC UA message and receive response"""
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(timeout)

    try:
        sock.connect((ip, port))
        sock.send(data)
        response = sock.recv(4096)
        return response
    finally:
        sock.close()

