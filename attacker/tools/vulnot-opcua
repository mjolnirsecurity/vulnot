@cli.command()
@click.option('--network', '-n', required=True, help='Network to scan (e.g., 10.0.4.0/24)')
@click.option('--port', '-p', default=4840, help='OPC UA port (default: 4840)')
def scan(network: str, port: int):
    """Scan network for OPC UA servers"""
    console.print("\n[bold blue]╔════════════════════════════════════════╗[/]")
    console.print("[bold blue]║      VULNOT OPC UA Server Scanner      ║[/]")
    console.print("[bold blue]╚════════════════════════════════════════╝[/]\n")

    console.print(f"[yellow]Scanning:[/] {network} on port {port}\n")

    import ipaddress
    try:
        net = ipaddress.ip_network(network, strict=False)
    except ValueError as e:
        console.print(f"[red]Invalid network: {e}[/]")
        return

    found = []
    with console.status("[bold green]Scanning...") as status:
        for ip in net.hosts():
            ip_str = str(ip)
            try:
                sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                sock.settimeout(0.5)
                result = sock.connect_ex((ip_str, port))
                if result == 0:
                    found.append({'ip': ip_str, 'port': port, 'status': 'OPC UA'})
                sock.close()
            except:
                pass

    if found:
        table = Table(title="Discovered OPC UA Servers")
        table.add_column("IP Address", style="cyan")
        table.add_column("Port", style="white")
        table.add_column("Status", style="green")

        for dev in found:
            table.add_row(dev['ip'], str(dev['port']), dev['status'])

        console.print(table)
    else:
        console.print("[yellow]No OPC UA servers found[/]")

    console.print(f"\n[green]Found {len(found)} OPC UA server(s)[/]\n")

