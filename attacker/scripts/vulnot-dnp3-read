#!/usr/bin/env python3
"""
VULNOT DNP3 Reader
Read data from DNP3 outstations (RTUs/IEDs)

Reads:
- Binary Inputs (breaker status, relay status)
- Analog Inputs (voltages, currents, power)
- Counters
"""

import argparse
import socket
import struct
import sys
from rich.console import Console
from rich.table import Table
from rich.panel import Panel

console = Console()

# DNP3 Constants
DNP3_START = b'\x05\x64'

# Object types
BINARY_INPUT = 1
BINARY_OUTPUT = 10
ANALOG_INPUT = 30
ANALOG_OUTPUT = 40
COUNTER = 20

# Power grid point mappings
SUBSTATION_BINARY_INPUTS = {
    0: "CB 52-1 Feeder 1 HV",
    1: "CB 52-2 Feeder 2 HV",
    2: "CB 52-3 XFMR 1 HV",
    3: "CB 52-4 XFMR 2 HV",
    4: "CB 52-5 Bus Tie",
    5: "CB 52-6 Out Feeder 1",
    6: "CB 52-7 Out Feeder 2",
    7: "CB 52-8 Out Feeder 3",
    8: "CB 52-9 Out Feeder 4",
    9: "CB 52-10 XFMR 1 LV",
    10: "CB 52-11 XFMR 2 LV",
    11: "CB 52-12 Spare",
    12: "DS 89-1",
    13: "DS 89-2",
    14: "DS 89-3",
    15: "DS 89-4",
    16: "Relay 50/51-1 OC",
    17: "Relay 50/51-2 OC",
    18: "Relay 87T-1 Diff",
    19: "Relay 87T-2 Diff",
    20: "Relay 21-1 Dist",
    21: "Relay 21-2 Dist",
    22: "Relay 81 Freq",
    23: "Relay 27 UV",
    24: "Relay 59 OV",
}

SUBSTATION_ANALOG_INPUTS = {
    0: ("System Frequency", "Hz", 1.0),
    1: ("Feeder 1 Va", "kV", 0.01),
    2: ("Feeder 1 Vb", "kV", 0.01),
    3: ("Feeder 1 Vc", "kV", 0.01),
    4: ("Feeder 1 Ia", "A", 0.01),
    5: ("Feeder 1 Ib", "A", 0.01),
