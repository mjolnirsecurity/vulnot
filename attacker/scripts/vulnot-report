def generate_markdown_report(report: AssessmentReport) -> str:
    """Generate Markdown report"""
    report.calculate_metrics()
    
    md = f"""# {report.title}

**Client:** {report.client}  
**Assessor:** {report.assessor}  
**Date:** {report.date}

---

## Executive Summary

{report.executive_summary}

### Key Metrics

| Metric | Value |
|--------|-------|
| Total Assets Assessed | {report.total_assets} |
| Critical Findings | {report.critical_findings} |
| High Findings | {report.high_findings} |
| Medium Findings | {report.medium_findings} |
| Low Findings | {report.low_findings} |
| IEC 62443 Compliance | {report.iec62443_score}% |
| NIST CSF Maturity | {report.nist_csf_score}% |

### Risk Rating

Based on the findings identified during this assessment, the overall security posture of the OT environment is rated as **CRITICAL RISK**.

---

## Scope

The following systems were included in this assessment:

"""
    
    for item in report.scope:
        md += f"- {item}\n"
    
    md += f"""

---

## Methodology

{report.methodology}

---

## Findings

"""
    
    for finding in sorted(report.findings, key=lambda x: {"critical": 0, "high": 1, "medium": 2, "low": 3, "info": 4}[x.severity]):
        severity_badge = {"critical": "🔴", "high": "🟠", "medium": "🟡", "low": "🔵", "info": "⚪"}[finding.severity]
        
        md += f"""### {finding.id}: {finding.title}

**Severity:** {severity_badge} {finding.severity.upper()} (CVSS {finding.cvss})  
**Protocol:** {finding.protocol}  
**MITRE ATT&CK:** {finding.mitre_technique}

#### Description

{finding.description}

#### Affected Assets

"""
        for asset in finding.affected_assets:
            md += f"- {asset}\n"
        
        md += f"""

#### Evidence

{finding.evidence}

#### Recommendation

{finding.recommendation}

#### Compliance Mapping

"""
        for mapping in finding.compliance_mapping:
            md += f"- {mapping}\n"
        
        md += "\n---\n\n"
    
    md += """## Remediation Roadmap

| Priority | Finding | Remediation | Timeline |
|----------|---------|-------------|----------|
"""
    
    priority = 1
    for finding in sorted(report.findings, key=lambda x: x.cvss, reverse=True)[:10]:
        timeline = "30 days" if finding.severity == "critical" else "60 days" if finding.severity == "high" else "90 days"
        md += f"| P{priority} | {finding.title} | {finding.recommendation[:50]}... | {timeline} |\n"
        priority += 1
    
    md += """

---

## Appendix A: MITRE ATT&CK for ICS Mapping

| Technique ID | Technique Name | Findings |
|--------------|----------------|----------|
"""
    
    techniques = {}
    for finding in report.findings:
        if finding.mitre_technique:
            tid = finding.mitre_technique.split(" - ")[0]
            if tid not in techniques:
                techniques[tid] = {"name": finding.mitre_technique, "findings": []}
            techniques[tid]["findings"].append(finding.id)
    
    for tid, data in techniques.items():
        md += f"| {tid} | {data['name']} | {', '.join(data['findings'])} |\n"
    
    md += f"""

---

## Appendix B: Tool Reference

The following tools were used during this assessment:

- `vulnot-scan` - Network discovery
- `vulnot-read` / `vulnot-write` - Modbus exploitation
- `vulnot-dnp3` - DNP3 protocol testing
- `vulnot-s7` - Siemens S7 testing
- `vulnot-opcua` - OPC UA testing
- `vulnot-mqtt` - MQTT testing
- `vulnot-historian` - Historian attacks
- `vulnot-forensics` - Evidence collection

---

*Report generated by VULNOT Assessment Report Generator*  
*{datetime.now().isoformat()}*
"""
    
    return md


def generate_html_report(report: AssessmentReport) -> str:
    """Generate HTML report"""
    md_content = generate_markdown_report(report)
    
    html = f"""<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{report.title}</title>
    <style>
        body {{
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            line-height: 1.6;
            max-width: 900px;
            margin: 0 auto;
            padding: 20px;
            background: #1a1a2e;
            color: #eee;
        }}
        h1, h2, h3 {{ color: #00d4ff; }}
        table {{ 
            border-collapse: collapse; 
            width: 100%; 
            margin: 20px 0;
        }}
        th, td {{ 
            border: 1px solid #333; 
            padding: 10px; 
            text-align: left; 
        }}
        th {{ background: #16213e; }}
        code {{ 
            background: #16213e; 
            padding: 2px 6px; 
            border-radius: 3px; 
        }}
        hr {{ border: 1px solid #333; margin: 30px 0; }}
        .critical {{ color: #ff4444; }}
        .high {{ color: #ff8c00; }}
        .medium {{ color: #ffd700; }}
        .low {{ color: #4da6ff; }}
    </style>
</head>
<body>
    <div id="content"></div>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script>
        const markdown = {json.dumps(md_content)};
        document.getElementById('content').innerHTML = marked.parse(markdown);
    </script>
</body>
</html>
"""
    return html


def cmd_generate(args):
    """Generate assessment report"""
    console.print("\n[bold cyan]╔════════════════════════════════════════╗[/]")
    console.print("[bold cyan]║    VULNOT Assessment Report Generator  ║[/]")
    console.print("[bold cyan]╚════════════════════════════════════════╝[/]\n")
    
    report = AssessmentReport(
        title=args.title or "OT Security Assessment Report",
        client=args.client or "Mjolnir Training",
        assessor=args.assessor or "Mjolnir Security",
        executive_summary="""This report presents the findings from an OT security assessment conducted against the client's industrial control systems environment. The assessment identified **multiple critical vulnerabilities** that could allow an attacker to gain unauthorized access to process control systems, manipulate industrial processes, and potentially cause physical damage or safety incidents.

**Key Findings:**
- All assessed OT protocols lack authentication
- Network segmentation is insufficient
- Default credentials in use on edge devices
- Historian vulnerable to SQL injection

**Immediate action is required** to address the critical findings before they can be exploited by malicious actors.""",
        scope=[
            "Water Treatment Plant (Modbus TCP) - 10.0.1.0/24",
            "Power Substation (DNP3) - 10.0.2.0/24",
            "Manufacturing Facility (S7comm) - 10.0.3.0/24",
            "Chemical Reactor (OPC UA) - 10.0.4.0/24",
            "Building Automation (BACnet) - 10.0.5.0/24",
            "Packaging Line (EtherNet/IP) - 10.0.6.0/24",
            "IIoT Sensor Network (MQTT) - 10.0.7.0/24",
            "CNC Motion Control (PROFINET) - 10.0.8.0/24",
            "OT Historian - 10.0.9.0/24",
        ],
        methodology="""The assessment was conducted using the following methodology:

1. **Reconnaissance** - Network discovery and asset identification using protocol-specific scanning tools
2. **Vulnerability Assessment** - Testing for authentication bypass, default credentials, and protocol weaknesses
3. **Exploitation** - Controlled exploitation to demonstrate impact (with authorization)
4. **Forensic Analysis** - Evidence collection and timeline reconstruction
5. **Compliance Mapping** - Mapping findings to IEC 62443 and NIST CSF frameworks

All testing was performed from isolated attacker workstations within the OT network segments.""",
        findings=SAMPLE_FINDINGS,
        total_assets=45,
        iec62443_score=42,
        nist_csf_score=38,
    )
    
    with Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        console=console,
    ) as progress:
        task = progress.add_task("Collecting findings...", total=None)
        
        progress.update(task, description="Calculating metrics...")
        report.calculate_metrics()
        
        progress.update(task, description=f"Generating {args.format.upper()} report...")
        
        if args.format == "markdown":
            content = generate_markdown_report(report)
            ext = "md"
        elif args.format == "html":
            content = generate_html_report(report)
            ext = "html"
        else:
            content = json.dumps(asdict(report), indent=2, default=str)
            ext = "json"
        
        output_file = args.output or f"vulnot_assessment_report.{ext}"
        
        progress.update(task, description="Writing report...")
        with open(output_file, 'w') as f:
            f.write(content)
    
    console.print(f"\n[green]✓ Report generated: {output_file}[/]")
    console.print(f"[green]✓ {len(report.findings)} findings documented[/]")
    console.print(f"[green]✓ Risk Rating: CRITICAL[/]\n")
    
    # Summary table
    table = Table(title="Finding Summary")
    table.add_column("Severity", style="cyan")
    table.add_column("Count", style="white")
    
    table.add_row("🔴 Critical", str(report.critical_findings))
    table.add_row("🟠 High", str(report.high_findings))
    table.add_row("🟡 Medium", str(report.medium_findings))
    table.add_row("🔵 Low", str(report.low_findings))
    
    console.print(table)


def main():
    parser = argparse.ArgumentParser(
        description='VULNOT Assessment Report Generator',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  vulnot-report generate -f markdown -o report.md
  vulnot-report generate -f html -o report.html --client "ACME Corp"
  vulnot-report generate -f json -o findings.json
        """
    )
    
    subparsers = parser.add_subparsers(dest='command')
    
    # Generate
    gen = subparsers.add_parser('generate', help='Generate report')
    gen.add_argument('-f', '--format', default='markdown', choices=['markdown', 'html', 'json'])
    gen.add_argument('-o', '--output', help='Output file')
    gen.add_argument('--title', help='Report title')
    gen.add_argument('--client', help='Client name')
    gen.add_argument('--assessor', help='Assessor name')
    
    args = parser.parse_args()
    
    if args.command == 'generate':
        cmd_generate(args)
    else:
        parser.print_help()


if __name__ == '__main__':
    main()
