def cmd_jog(args):
    """Send jog command to axis"""
    console.print("\n[bold red]╔════════════════════════════════════════╗[/]")
    console.print("[bold red]║      VULNOT PROFINET Jog Command       ║[/]")
    console.print("[bold red]║   ⚠️  MOTION CONTROL - USE CAUTION      ║[/]")
    console.print("[bold red]╚════════════════════════════════════════╝[/]\n")
    
    console.print(f"[yellow]Target: {args.target}[/]")
    console.print(f"[yellow]Axis: {args.axis}[/]")
    console.print(f"[yellow]Distance: {args.distance} mm[/]")
    console.print(f"[yellow]Velocity: {args.velocity} mm/s[/]\n")
    
    console.print(Panel(
        "[bold red]WARNING: This command will cause physical motion![/]\n\n"
        "Ensure:\n"
        "• Machine is in safe state\n"
        "• No personnel in work envelope\n"
        "• E-stop is accessible\n"
        "• Motion path is clear",
        title="⚠️ SAFETY WARNING",
        border_style="red"
    ))
    
    if not args.force:
        if not Confirm.ask("\n[bold red]Execute jog command?[/]"):
            console.print("[yellow]Aborted[/]")
            return
    
    console.print(f"\n[red]⚠️ Jogging {args.axis} axis by {args.distance}mm at {args.velocity}mm/s[/]")
    
    with Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        console=console,
    ) as progress:
        task = progress.add_task("Moving...", total=None)
        time.sleep(2)
        
    console.print(f"[green]✓ Motion complete[/]")
    console.print(f"[green]✓ New position: {245.678 + args.distance}mm[/]")


def cmd_stop(args):
    """Emergency stop drive"""
    console.print("\n[bold red]╔════════════════════════════════════════╗[/]")
    console.print("[bold red]║      VULNOT PROFINET DRIVE STOP        ║[/]")
    console.print("[bold red]║   ⚠️  EMERGENCY COMMAND                 ║[/]")
    console.print("[bold red]╚════════════════════════════════════════╝[/]\n")
    
    console.print(f"[yellow]Target: {args.target}[/]\n")
    
    if not args.force:
        if not Confirm.ask("[bold red]Send drive STOP command?[/]"):
            console.print("[yellow]Aborted[/]")
            return
    
    console.print("[red]⚠️ Sending QUICK STOP to all axes...[/]")
    time.sleep(0.5)
    
    for axis in ["X", "Y", "Z", "A", "C", "Spindle"]:
        console.print(f"  [red]• {axis}: STOPPED[/]")
        time.sleep(0.2)
        
    console.print(f"\n[red]⚠️ All drives in QUICK_STOP state[/]")
    console.print("[yellow]Manual reset required to resume operation[/]")


def cmd_attack(args):
    """Execute predefined attack scenarios"""
    console.print("\n[bold red]╔════════════════════════════════════════╗[/]")
    console.print("[bold red]║      VULNOT PROFINET Attack Scenarios  ║[/]")
    console.print("[bold red]║   ⚠️  EXPLOITATION MODULE               ║[/]")
    console.print("[bold red]╚════════════════════════════════════════╝[/]\n")
    
    attacks = {
        "velocity_override": {
            "name": "Velocity Override Attack",
            "description": "Override velocity limits to cause excessive speed",
            "impact": "Equipment damage, safety hazard",
            "mitre": "T0836",
        },
        "position_offset": {
            "name": "Position Offset Injection",
            "description": "Inject position offset causing dimensional errors",
            "impact": "Quality defects, scrap production",
            "mitre": "T0831",
        },
        "drive_disable": {
            "name": "Drive Disable Attack",
            "description": "Disable servo drives causing loss of control",
            "impact": "Machine crash, production stop",
            "mitre": "T0816",
        },
        "torque_limit": {
            "name": "Torque Limit Manipulation",
            "description": "Remove torque limits causing mechanical damage",
            "impact": "Motor burnout, mechanical failure",
            "mitre": "T0836",
        },
        "safety_bypass": {
            "name": "Safety Function Bypass",
            "description": "Attempt to bypass STO/SLS safety functions",
            "impact": "Life safety compromise",
            "mitre": "T0837",
        },
    }
    
    if args.scenario not in attacks:
        console.print("[yellow]Available attack scenarios:[/]\n")
        for name, info in attacks.items():
            console.print(f"  [cyan]{name}[/]")
            console.print(f"    {info['description']}")
            console.print(f"    Impact: [red]{info['impact']}[/]")
            console.print(f"    MITRE: {info['mitre']}\n")
        return
        
    attack = attacks[args.scenario]
    
    console.print(f"[yellow]Attack: {attack['name']}[/]")
    console.print(f"[yellow]Target: {args.target}[/]")
    console.print(f"[red]Impact: {attack['impact']}[/]\n")
    
    if not args.force:
        if not Confirm.ask(f"[bold red]Execute {attack['name']}?[/]"):
            console.print("[yellow]Aborted[/]")
            return
    
    console.print(f"\n[red]Executing {attack['name']}...[/]\n")
    
    with Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        console=console,
    ) as progress:
        if args.scenario == "velocity_override":
            task = progress.add_task("Reading current velocity limits...", total=None)
            time.sleep(1)
            progress.update(task, description="Modifying X axis max velocity...")
            time.sleep(0.5)
            progress.update(task, description="Modifying Y axis max velocity...")
            time.sleep(0.5)
            progress.update(task, description="Modifying Z axis max velocity...")
            time.sleep(0.5)
            
        elif args.scenario == "position_offset":
            task = progress.add_task("Reading position feedback...", total=None)
            time.sleep(1)
            progress.update(task, description="Injecting offset to encoder feedback...")
            time.sleep(1)
            
        elif args.scenario == "drive_disable":
            task = progress.add_task("Sending control word 0x0000...", total=None)
            time.sleep(1)
            progress.update(task, description="Drives transitioning to SWITCH_ON_DISABLED...")
            time.sleep(1)
            
    console.print(f"\n[red]✓ Attack complete: {attack['name']}[/]")
    console.print(f"[yellow]MITRE ATT&CK: {attack['mitre']}[/]")


def main():
    parser = argparse.ArgumentParser(
        description='VULNOT PROFINET Attack Tool',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  vulnot-profinet scan -n 10.0.8.0/24
  vulnot-profinet info -t 10.0.8.10
  vulnot-profinet read -t 10.0.8.10 -a X
  vulnot-profinet jog -t 10.0.8.10 -a X -d 10 -v 1000
  vulnot-profinet stop -t 10.0.8.10
  vulnot-profinet attack -t 10.0.8.10 -s velocity_override
        """
    )
    
    subparsers = parser.add_subparsers(dest='command')
    
    # Scan
    scan = subparsers.add_parser('scan', help='Scan for PROFINET devices')
    scan.add_argument('-n', '--network', default='10.0.8.0/24', help='Network to scan')
    
    # Info
    info = subparsers.add_parser('info', help='Get device information')
    info.add_argument('-t', '--target', required=True, help='Target IP')
    info.add_argument('-p', '--port', type=int, default=PROFINET_RT_PORT, help='Port')
    
    # Read
    read = subparsers.add_parser('read', help='Read drive parameters')
    read.add_argument('-t', '--target', required=True, help='Target IP')
    read.add_argument('-a', '--axis', default='all', help='Axis (X, Y, Z, Spindle, all)')
    
    # Jog
    jog = subparsers.add_parser('jog', help='Jog axis')
    jog.add_argument('-t', '--target', required=True, help='Target IP')
    jog.add_argument('-a', '--axis', required=True, help='Axis')
    jog.add_argument('-d', '--distance', type=float, required=True, help='Distance (mm)')
    jog.add_argument('-v', '--velocity', type=float, default=1000, help='Velocity (mm/s)')
    jog.add_argument('--force', action='store_true', help='Skip confirmation')
    
    # Stop
    stop = subparsers.add_parser('stop', help='Emergency stop')
    stop.add_argument('-t', '--target', required=True, help='Target IP')
    stop.add_argument('--force', action='store_true', help='Skip confirmation')
    
    # Attack
    attack = subparsers.add_parser('attack', help='Execute attack scenario')
    attack.add_argument('-t', '--target', required=True, help='Target IP')
    attack.add_argument('-s', '--scenario', default='', help='Attack scenario')
    attack.add_argument('--force', action='store_true', help='Skip confirmation')
    
    args = parser.parse_args()
    
    if args.command == 'scan':
        cmd_scan(args)
    elif args.command == 'info':
        cmd_info(args)
    elif args.command == 'read':
        cmd_read(args)
    elif args.command == 'jog':
        cmd_jog(args)
    elif args.command == 'stop':
        cmd_stop(args)
    elif args.command == 'attack':
        cmd_attack(args)
    else:
        parser.print_help()


if __name__ == '__main__':
    main()
