#!/usr/bin/env python3
"""
VULNOT Modbus Monitor
Real-time monitoring of Modbus device registers
"""

import argparse
import sys
import time
from pymodbus.client import ModbusTcpClient
from rich.console import Console
from rich.live import Live
from rich.table import Table
from rich.panel import Panel
from rich.layout import Layout

console = Console()

# Register mappings (same as vulnot-read)
PLC_MAPPINGS = {
    1: {
        'name': 'PLC-INTAKE',
        'description': 'Raw Water Intake & Pumping',
        'holding_registers': {
            0: ('Intake Level', '%', 100),
            1: ('Raw Water Flow', 'GPM', 1),
            2: ('Pump P101 Speed', '%', 100),
            3: ('Pump P102 Speed', '%', 100),
            4: ('Intake Pressure', 'PSI', 100),
            5: ('Raw Turbidity', 'NTU', 100),
            6: ('Raw pH', 'pH', 100),
            7: ('Temperature', '°C', 100),
        },
        'coils': {
            0: 'Pump P101 Run',
            1: 'Pump P102 Run',
        }
    },
    2: {
        'name': 'PLC-TREATMENT',
        'description': 'Water Treatment Process',
        'holding_registers': {
            0: ('Flash Mix Level', '%', 100),
            1: ('Floc Basin Level', '%', 100),
            2: ('Sed Basin Level', '%', 100),
            3: ('Chlorine Contact Level', '%', 100),
            4: ('Chlorine Flow', 'GPH', 100),
            5: ('Alum Flow', 'GPH', 100),
            6: ('Treated pH', 'pH', 100),
            7: ('Chlorine Residual', 'mg/L', 100),
            8: ('Filtered Turbidity', 'NTU', 1000),
            9: ('Chemical Valve Position', '%', 100),
        },
        'coils': {
            0: 'Transfer Pump P201 Run',
            1: 'Transfer Pump P202 Run',
        }
    },
    3: {
        'name': 'PLC-DISTRIBUTION',
        'description': 'Clearwell & Distribution',
        'holding_registers': {
            0: ('Clearwell Level', '%', 100),
            1: ('Distribution Flow', 'GPM', 1),
            2: ('Distribution Pressure', 'PSI', 100),
            3: ('Pump P301 Speed', '%', 100),
            4: ('Pump P302 Speed', '%', 100),
            5: ('Treated Flow', 'GPM', 1),
            6: ('Filter DP', 'PSI', 100),
            7: ('Distribution Valve Position', '%', 100),
        },
        'coils': {
            0: 'Dist Pump P301 Run',
            1: 'Dist Pump P302 Run',
        }
    }
}

def read_data(client, unit_id):
    """Read all registers and coils from device"""
    data = {'registers': {}, 'coils': {}}
    
    try:
        # Read holding registers
        result = client.read_holding_registers(0, 10, slave=unit_id)
        if not result.isError():
            data['registers'] = {i: v for i, v in enumerate(result.registers)}
        
        # Read coils
        result = client.read_coils(0, 8, slave=unit_id)
        if not result.isError():
            data['coils'] = {i: v for i, v in enumerate(result.bits[:8])}
            
    except Exception as e:
        console.print(f"[red]Read error: {e}[/]")
    
    return data

def create_display(data, unit_id, prev_data=None):
    """Create the display table"""
    mapping = PLC_MAPPINGS.get(unit_id, {})
    
    layout = Layout()
    
    # Header
    header = Panel(
        f"[bold cyan]{mapping.get('name', f'Unit {unit_id}')}[/] - {mapping.get('description', 'Unknown')}",
        title="VULNOT Monitor",
        border_style="cyan"
    )
    
    # Registers table
    reg_table = Table(title="Holding Registers", expand=True)
    reg_table.add_column("Addr", style="cyan", width=6)
    reg_table.add_column("Name", style="white")
    reg_table.add_column("Value", style="green", justify="right")
    reg_table.add_column("Δ", style="yellow", width=8)
    
    reg_mapping = mapping.get('holding_registers', {})
    for addr, value in data['registers'].items():
        name = '-'
        display_value = str(value)
        
        if addr in reg_mapping:
            name, unit, scale = reg_mapping[addr]
            scaled = value / scale
            display_value = f"{scaled:.2f} {unit}"
        
        # Calculate delta
        delta = ''
        if prev_data and addr in prev_data.get('registers', {}):
            prev_value = prev_data['registers'][addr]
            if value != prev_value:
                diff = value - prev_value
                if addr in reg_mapping:
                    _, _, scale = reg_mapping[addr]
                    diff = diff / scale
                delta = f"[{'green' if diff > 0 else 'red'}]{'+' if diff > 0 else ''}{diff:.2f}[/]"
        
        reg_table.add_row(f"HR[{addr}]", name, display_value, delta)
    
    # Coils table
    coil_table = Table(title="Coils", expand=True)
    coil_table.add_column("Addr", style="cyan", width=8)
    coil_table.add_column("Name", style="white")
    coil_table.add_column("Status", style="green", justify="center")
    
    coil_mapping = mapping.get('coils', {})
    for addr, value in data['coils'].items():
        name = coil_mapping.get(addr, '-')
        status = "[green]● ON[/]" if value else "[red]○ OFF[/]"
        coil_table.add_row(f"COIL[{addr}]", name, status)
    
    return Panel(
        f"{header.renderable}\n\n{reg_table}\n\n{coil_table}\n\n[dim]Press Ctrl+C to stop[/]",
        border_style="cyan"
    )

def main():
    parser = argparse.ArgumentParser(description='VULNOT Modbus Monitor')
    parser.add_argument('-t', '--target', required=True,
                        help='Target IP address')
    parser.add_argument('-p', '--port', type=int, default=502,
                        help='Modbus port (default: 502)')
    parser.add_argument('-u', '--unit', type=int, default=1,
                        help='Unit ID (default: 1)')
    parser.add_argument('-i', '--interval', type=float, default=1.0,
                        help='Update interval in seconds (default: 1.0)')
    
    args = parser.parse_args()
    
    console.print("\n[bold cyan]╔════════════════════════════════════════╗[/]")
    console.print("[bold cyan]║     VULNOT Real-Time Modbus Monitor    ║[/]")
    console.print("[bold cyan]╚════════════════════════════════════════╝[/]\n")
    
    console.print(f"[yellow]Connecting to {args.target}:{args.port} (Unit {args.unit})...[/]")
    
    client = ModbusTcpClient(args.target, port=args.port)
    if not client.connect():
        console.print("[red]Failed to connect to target[/]")
        sys.exit(1)
    
    console.print("[green]Connected! Starting monitor...[/]\n")
    
    prev_data = None
    
    try:
        with Live(console=console, refresh_per_second=2) as live:
            while True:
                data = read_data(client, args.unit)
                display = create_display(data, args.unit, prev_data)
                live.update(display)
                prev_data = data
                time.sleep(args.interval)
                
    except KeyboardInterrupt:
        console.print("\n[yellow]Monitor stopped[/]")
    finally:
        client.close()
        console.print("[dim]Connection closed[/]\n")

if __name__ == '__main__':
    main()
